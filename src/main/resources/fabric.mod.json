{
  "schemaVersion": 1,
  "id": "derggycraft",
  "version": "${version}",

  "name": "DerggyCraft",
  "description": "DerggyCraft mod for Minecraft Beta 1.7.3",
  "authors": [
    "Derggy"
  ],
  "contact": {
  },

  "license": "CC0-1.0",
  "icon": "assets/derggycraft/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      "net.derggy.craft.derggycraft.events.init.InitListener",
      "net.derggy.craft.derggycraft.config.DerggyCraftConfig",
      "net.derggy.craft.derggycraft.events.init.ItemInit",
      "net.derggy.craft.derggycraft.events.init.BlockInit",
      "net.derggy.craft.derggycraft.events.init.RecipeInit",
      "net.derggy.craft.derggycraft.network.CompassNetworkInit",
      "net.derggy.craft.derggycraft.network.MusicNetworkInit"
    ],
    "stationapi:event_bus_client": [
      "net.derggy.craft.derggycraft.events.init.TextureInit"
    ],
    "stationapi:event_bus_server": [
    ]
  },
  "mixins": [
    "derggycraft.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "gcapi3": "*",
    "stationapi": "*"
  }
}
